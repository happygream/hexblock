# HexBlock environment configuration
# Copy to .env before deploying: cp .env.example .env
# Never commit .env to version control.

# ── Core ──────────────────────────────────────────────────────
HEXBLOCK_ENV=production

# Generated by install.sh — do not set this manually
SECRET_KEY=

# ── Data paths ────────────────────────────────────────────────
# These match the Docker volume mounts in docker-compose.yml.
# Do not change unless you remap the volumes.
DB_PATH=/data/db/hexblock.db
BLOCKLIST_DIR=/data/blocklists
LOG_DIR=/data/logs

# ── Reverse proxy ─────────────────────────────────────────────
# Choose one mode. Do not set both.
#
# TRUST_PROXY=1
#   Trust X-Forwarded-For from any upstream proxy (Nginx, Caddy, Traefik).
#   Only use this if HexBlock is not directly internet-facing.
#
# TRUST_CLOUDFLARE=1
#   Trust CF-Connecting-IP only from verified Cloudflare IP ranges.
#   Use this when running behind a Cloudflare Tunnel.
#   HexBlock fetches Cloudflare's published IP list at startup.
#
TRUST_PROXY=0
TRUST_CLOUDFLARE=0

# Comma-separated allowed hostnames. Use * to allow all.
# Set to your domain when behind a reverse proxy to prevent host header injection.
# Example: ALLOWED_HOSTS=hexblock.example.com,hexblock.local
ALLOWED_HOSTS=*

# Sub-path prefix — only needed if serving under a path, not a domain root.
# Example: ROOT_PATH=/hexblock
# Leave blank for the vast majority of deployments.
ROOT_PATH=

# ── DNS ───────────────────────────────────────────────────────
DNSMASQ_HOSTS_FILE=/etc/dnsmasq.d/hexblock.hosts
DNSMASQ_RELOAD_CMD=killall -HUP dnsmasq

# ── WireGuard ─────────────────────────────────────────────────
WG_INTERFACE=wg0
WG_PORT=51820
WG_SUBNET=10.13.13.0/24

# ── Security ──────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_SECONDS=300
SESSION_LIFETIME=3600

# ── Scheduler ─────────────────────────────────────────────────
AUTO_UPDATE_HOUR=3

# ── Timezone ──────────────────────────────────────────────────
TZ=Europe/London
